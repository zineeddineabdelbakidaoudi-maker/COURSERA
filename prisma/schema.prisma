generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ━━━ ENUMS ━━━
enum Role {
  buyer
  seller
  publisher
  admin
}

enum SellerStatus {
  none
  pending
  approved
  rejected
  suspended
}

enum PublisherStatus {
  disabled
  enabled
}

enum SellerLevel {
  new
  rising
  pro
  elite
}

enum VerificationBadge {
  none
  id_verified
  pro_verified
}

enum ServiceStatus {
  draft
  pending_review
  live
  paused
  rejected
}

enum ProductStatus {
  draft
  pending_review
  live
  rejected
}

enum ProductType {
  course
  ebook
  template
  toolkit
  bundle
}

enum CategoryType {
  services
  products
  both
}

enum OrderStatus {
  pending_requirements
  in_progress
  delivered
  revision_requested
  completed
  disputed
  cancelled
  refunded
}

enum ItemType {
  service
  product
}

enum LicenseType {
  personal
  commercial
  extended
}

enum LanguageType {
  ar
  fr
  en
  multi
}

enum DiscountType {
  percent
  fixed
}

enum PayoutStatus {
  requested
  processing
  completed
  rejected
}

enum JobStatus {
  open
  in_progress
  completed
  cancelled
}

enum ProposalStatus {
  pending
  accepted
  rejected
  withdrawn
}

enum PaymentMethod {
  cib
  edahabia
  bank_transfer
}

// ━━━ MODELS ━━━

model Profile {
  id                           String            @id // Matches Supabase auth.users.id
  full_name                    String?
  username                     String?           @unique
  email                        String            @unique
  avatar_url                   String?
  bio                          String?
  city                         String?
  country                      String            @default("DZ")
  phone_whatsapp               String?
  languages                    String[]
  role                         Role              @default(buyer)
  seller_status                SellerStatus      @default(none)
  publisher_status             PublisherStatus   @default(disabled)
  publisher_allowed_categories String[]          @default([]) // uuid[] in DB
  seller_level                 SellerLevel       @default(new)
  rating_avg                   Decimal           @default(0) @db.Decimal(3, 2)
  total_reviews                Int               @default(0)
  total_orders_completed       Int               @default(0)
  response_rate                Decimal?          @db.Decimal(5, 2)
  is_verified                  Boolean           @default(false)
  verification_badge_type      VerificationBadge @default(none)
  referral_code                String?           @unique
  referred_by_id               String?
  referred_by                  Profile?          @relation("Referrals", fields: [referred_by_id], references: [id])
  referred_users               Profile[]         @relation("Referrals")
  credit_balance_dzd           Decimal           @default(0) @db.Decimal(10, 2)
  stripe_customer_id           String?
  created_at                   DateTime          @default(now())
  updated_at                   DateTime          @updatedAt

  // Relations
  services                     Service[]
  digital_products             DigitalProduct[]
  orders_as_buyer              Order[]           @relation("BuyerOrders")
  orders_as_seller             Order[]           @relation("SellerOrders")
  product_purchases            ProductPurchase[]
  cart_items                   CartItem[]
  messages                     Message[]
  reviews_given                Review[]          @relation("ReviewsGiven")
  reviews_received             Review[]          @relation("ReviewsReceived")
  notifications                Notification[]
  payouts                      Payout[]
  wishlists                    Wishlist[]
  admin_activity_logs          AdminActivityLog[]
  jobs_posted                  Job[]             @relation("BuyerJobs")
  proposals_submitted          Proposal[]        @relation("SellerProposals")
}

model Category {
  id               String           @id @default(uuid())
  name_en          String
  name_ar          String
  name_fr          String
  slug             String           @unique
  icon             String?
  type             CategoryType
  is_active        Boolean          @default(true)
  display_order    Int              @default(0)
  
  services         Service[]
  digital_products DigitalProduct[]
  jobs             Job[]
}

model Service {
  id                 String        @id @default(uuid())
  seller_id          String
  seller             Profile       @relation(fields: [seller_id], references: [id], onDelete: Cascade)
  title              String
  slug               String        @unique
  description        String
  category_id        String
  category           Category      @relation(fields: [category_id], references: [id])
  subcategory_id     String?
  tags               String[]
  status             ServiceStatus @default(draft)
  rejection_reason   String?
  thumbnail_url      String?
  gallery_urls       String[]
  packages           Json?         // basic, standard, premium details
  addons             Json?         // optional extras
  faq                Json?
  order_requirements Json?
  rating_avg         Decimal       @default(0) @db.Decimal(3, 2)
  total_reviews      Int           @default(0)
  total_orders       Int           @default(0)
  views_count        Int           @default(0)
  is_featured        Boolean       @default(false)
  created_at         DateTime      @default(now())
  updated_at         DateTime      @updatedAt

  orders             Order[]
  cart_items         CartItem[]
  reviews            Review[]
  wishlisted_by      Wishlist[]
}

model DigitalProduct {
  id                   String        @id @default(uuid())
  publisher_id         String
  publisher            Profile       @relation(fields: [publisher_id], references: [id], onDelete: Cascade)
  title                String
  slug                 String        @unique
  description          String
  type                 ProductType
  category_id          String
  category             Category      @relation(fields: [category_id], references: [id])
  tags                 String[]
  status               ProductStatus @default(draft)
  rejection_reason     String?
  cover_url            String?
  preview_urls         String[]
  file_url             String        // private storage path
  file_size_mb         Decimal?      @db.Decimal(10, 2)
  file_format          String?
  price_dzd            Decimal       @db.Decimal(10, 2)
  is_free              Boolean       @default(false)
  license_type         LicenseType
  language             LanguageType
  rating_avg           Decimal       @default(0) @db.Decimal(3, 2)
  total_reviews        Int           @default(0)
  total_purchases      Int           @default(0)
  is_featured          Boolean       @default(false)
  is_best_seller       Boolean       @default(false)
  what_youll_get       String[]
  who_is_this_for      String[]
  created_at           DateTime      @default(now())
  updated_at           DateTime      @updatedAt

  purchases            ProductPurchase[]
  cart_items           CartItem[]
  reviews              Review[]
  wishlisted_by        Wishlist[]
}

model Order {
  id                   String      @id @default(uuid())
  order_number         String      @unique // format: DH-YYYYXXXX
  buyer_id             String
  buyer                Profile     @relation("BuyerOrders", fields: [buyer_id], references: [id])
  seller_id            String
  seller               Profile     @relation("SellerOrders", fields: [seller_id], references: [id])
  service_id           String
  service              Service     @relation(fields: [service_id], references: [id])
  package_name         String
  package_details      Json?
  addons               Json?
  status               OrderStatus @default(pending_requirements)
  price_dzd            Decimal     @db.Decimal(10, 2)
  platform_fee_dzd     Decimal     @db.Decimal(10, 2)
  seller_payout_dzd    Decimal     @db.Decimal(10, 2)
  requirements_data    Json?
  delivery_files       String[]
  delivery_message     String?
  revisions_used       Int         @default(0)
  revisions_allowed    Int         @default(0)
  deadline_at          DateTime?
  delivered_at         DateTime?
  completed_at         DateTime?
  auto_complete_at     DateTime?
  created_at           DateTime    @default(now())
  updated_at           DateTime    @updatedAt

  conversations        Conversation[]
  reviews              Review[]
}

model ProductPurchase {
  id                   String         @id @default(uuid())
  buyer_id             String
  buyer                Profile        @relation(fields: [buyer_id], references: [id])
  product_id           String
  product              DigitalProduct @relation(fields: [product_id], references: [id])
  price_paid_dzd       Decimal        @db.Decimal(10, 2)
  platform_fee_dzd     Decimal        @db.Decimal(10, 2)
  publisher_payout_dzd Decimal        @db.Decimal(10, 2)
  download_token       String         @unique
  download_count       Int            @default(0)
  max_downloads        Int            @default(5)
  stripe_payment_id    String?
  created_at           DateTime       @default(now())
}

model CartItem {
  id           String          @id @default(uuid())
  user_id      String
  user         Profile         @relation(fields: [user_id], references: [id], onDelete: Cascade)
  item_type    ItemType
  service_id   String?
  service      Service?        @relation(fields: [service_id], references: [id], onDelete: SetNull)
  product_id   String?
  product      DigitalProduct? @relation(fields: [product_id], references: [id], onDelete: SetNull)
  package_name String?
  addons       Json?
  quantity     Int             @default(1)
  created_at   DateTime        @default(now())
}

model Conversation {
  id              String    @id @default(uuid())
  participant_ids String[]  // Array of user IDs
  order_id        String?
  order           Order?    @relation(fields: [order_id], references: [id], onDelete: SetNull)
  last_message_at DateTime?
  created_at      DateTime  @default(now())

  messages        Message[]
}

model Message {
  id              String       @id @default(uuid())
  conversation_id String
  conversation    Conversation @relation(fields: [conversation_id], references: [id], onDelete: Cascade)
  sender_id       String
  sender          Profile      @relation(fields: [sender_id], references: [id], onDelete: Cascade)
  content         String
  attachment_url  String?
  is_read         Boolean      @default(false)
  created_at      DateTime     @default(now())
}

model Review {
  id                   String          @id @default(uuid())
  reviewer_id          String
  reviewer             Profile         @relation("ReviewsGiven", fields: [reviewer_id], references: [id], onDelete: Cascade)
  reviewed_user_id     String?
  reviewed_user        Profile?        @relation("ReviewsReceived", fields: [reviewed_user_id], references: [id], onDelete: SetNull)
  service_id           String?
  service              Service?        @relation(fields: [service_id], references: [id], onDelete: SetNull)
  product_id           String?
  product              DigitalProduct? @relation(fields: [product_id], references: [id], onDelete: SetNull)
  order_id             String?
  order                Order?          @relation(fields: [order_id], references: [id], onDelete: SetNull)
  rating_overall       Int             @db.SmallInt // 1-5
  rating_quality       Int             @db.SmallInt // 1-5
  rating_communication Int             @db.SmallInt // 1-5
  comment              String
  seller_reply         String?
  is_verified_purchase Boolean         @default(true)
  is_visible           Boolean         @default(false)
  buyer_submitted_at   DateTime?
  seller_submitted_at  DateTime?
  revealed_at          DateTime?
  created_at           DateTime        @default(now())
}

model Notification {
  id         String   @id @default(uuid())
  user_id    String
  user       Profile  @relation(fields: [user_id], references: [id], onDelete: Cascade)
  type       String
  title      String
  body       String
  link       String?
  is_read    Boolean  @default(false)
  created_at DateTime @default(now())
}

model Payout {
  id              String        @id @default(uuid())
  seller_id       String
  seller          Profile       @relation(fields: [seller_id], references: [id])
  amount_dzd      Decimal       @db.Decimal(10, 2)
  status          PayoutStatus  @default(requested)
  payment_method  PaymentMethod
  account_details Json
  admin_note      String?
  processed_at    DateTime?
  created_at      DateTime      @default(now())
}

model Wishlist {
  id         String          @id @default(uuid())
  user_id    String
  user       Profile         @relation(fields: [user_id], references: [id], onDelete: Cascade)
  item_type  ItemType
  service_id String?
  service    Service?        @relation(fields: [service_id], references: [id], onDelete: Cascade)
  product_id String?
  product    DigitalProduct? @relation(fields: [product_id], references: [id], onDelete: Cascade)
  created_at DateTime        @default(now())
}

model PromoCode {
  id             String       @id @default(uuid())
  code           String       @unique
  discount_type  DiscountType
  discount_value Decimal      @db.Decimal(10, 2)
  min_order_dzd  Decimal?     @db.Decimal(10, 2)
  max_uses       Int?
  used_count     Int          @default(0)
  expires_at     DateTime?
  is_active      Boolean      @default(true)
}

model ChatbotFaq {
  id            String  @id @default(uuid())
  question_ar   String
  question_fr   String
  question_en   String
  answer_ar     String
  answer_fr     String
  answer_en     String
  category      String
  display_order Int     @default(0)
  is_active     Boolean @default(true)
}

model AdminActivityLog {
  id          String   @id @default(uuid())
  admin_id    String
  admin       Profile  @relation(fields: [admin_id], references: [id])
  action_type String
  target_type String
  target_id   String   // Can be uuid, so leaving as string to handle varying formats
  details     Json?
  created_at  DateTime @default(now())
}

model Job {
  id               String       @id @default(uuid())
  buyer_id         String
  buyer            Profile      @relation("BuyerJobs", fields: [buyer_id], references: [id])
  title            String
  description      String
  category_id      String
  category         Category     @relation(fields: [category_id], references: [id])
  skills           String[]
  budget_dzd       Decimal?     @db.Decimal(10, 2)
  delivery_time    String?
  status           JobStatus    @default(open)
  created_at       DateTime     @default(now())
  updated_at       DateTime     @updatedAt

  proposals        Proposal[]
}

model Proposal {
  id               String         @id @default(uuid())
  job_id           String
  job              Job            @relation(fields: [job_id], references: [id], onDelete: Cascade)
  seller_id        String
  seller           Profile        @relation("SellerProposals", fields: [seller_id], references: [id])
  cover_letter     String
  bid_amount_dzd   Decimal        @db.Decimal(10, 2)
  delivery_time    String
  status           ProposalStatus @default(pending)
  created_at       DateTime       @default(now())
  updated_at       DateTime       @updatedAt
}
